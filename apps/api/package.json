{
  "name": "@myfetus/api",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "jwt:secret:test": "NODE_ENV=test node ./scripts/generate-jwt-secret.js",
    "jwt:test-token": "node ./scripts/generate-jwt-test-token.js",
    "jwt:rotate:test": "node ./scripts/rotate-jwt-secret-and-generate-token.js",
    "extract:documents": "node workers/extractDocuments.js",
    "rag:ingest": "node workers/ingestRagDocuments.js",
    "rag:test-search": "node tests/ragSearch.test.js",
    "test:chunking": "node tests/chunkingService.test.js",
    "test:embedding": "node tests/embeddingService.test.js",
    "test:pinecone": "node tests/vectorStoreService.test.js",
    "test:pii": "node ./tests/piiSanitizer.test.js",
    "test:logger": "node ./tests/logger.test.js",
    "test:db": "docker compose run --rm backend node /app/tests/database.test.js",
    "test:loinc": "docker compose run --rm backend node /app/tests/loincMapper.test.js",
    "test:loinc:endpoint": "docker compose run --rm backend node /app/tests/internalLoinc.test.js",
    "test:rag": "node ./tests/ragRetrieval.test.js",
    "test:stress-engine": "node ./tests/stressEngine.test.js",
    "test:stress": "node ./tests/stressTest.test.js",
    "test:stress:integration": "node ./tests/stressIntegration.test.js --integration",
    "test:hadlockCalculator": "node ./tests/hadlockCalculator.test.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@napi-rs/canvas": "^0.1.80",
    "@pinecone-database/pinecone": "^6.1.4",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.0",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.16.0",
    "tesseract.js": "^6.0.1"
  }
}
