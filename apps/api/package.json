{
  "name": "@myfetus/api",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "jwt:secret": "node ./scripts/generate-jwt-secret.js",
    "jwt:test-token": "node ./scripts/generate-jwt-test-token.js",
    "jwt:rotate": "node ./scripts/rotate-jwt-secret-and-generate-token.js",
    "db:rotate-password": "node ./scripts/rotate-database-password.js",
    "aes:key": "node ./scripts/generate-aes-key.js",
    "aes:init": "node ./scripts/initialize-data-protection-keys.js",
    "aes:migrate": "node ./scripts/migrate-encrypted-data.js --host=127.0.0.1 --port=5434",
    "aes:migrate:dry-run": "node ./scripts/migrate-encrypted-data.js --host=127.0.0.1 --port=5434 --dry-run",
    "extract:documents": "node workers/extractDocuments.js",
    "rag:ingest": "node workers/ingestRagDocuments.js",
    "rag:test-search": "node tests/ragSearch.test.js",
    "test:chunking": "node tests/chunkingService.test.js",
    "test:embedding": "node tests/embeddingService.test.js",
    "test:pinecone": "node tests/vectorStoreService.test.js",
    "test:pii": "node ./tests/piiSanitizer.test.js",
    "test:logger": "node ./tests/logger.test.js",
    "test:security-baseline": "node ./tests/securityBaseline.test.js",
    "test:transport-security": "node ./tests/transportSecurity.test.js",
    "test:crypto": "node ./tests/cryptoService.test.js",
    "test:file-crypto": "node ./tests/fileCryptoService.test.js",
    "test:clinical-crypto": "node ./tests/cryptoService.test.js && node ./tests/clinicalDataService.test.js && node ./tests/emailLookupService.node.test.js",
    "test:user-crypto-integration": "node ./tests/userCryptoIntegration.test.js",
    "test:clinical-crypto-integration": "node ./tests/clinicalCryptoIntegration.test.js",
    "test:encryption-schema-integration": "node ./tests/encryptionSchemaIntegration.test.js",
    "test:document-security-integration": "node ./tests/documentSecurityIntegration.test.js",
    "test:data-migration-integration": "node ./tests/dataEncryptionMigrationIntegration.test.js",
    "test:db": "docker compose run --rm backend node /app/tests/database.test.js",
    "test:loinc": "docker compose run --rm backend node /app/tests/loincMapper.test.js",
    "test:loinc:endpoint": "docker compose run --rm backend node /app/tests/internalLoinc.test.js",
    "test:rag": "node ./tests/ragRetrieval.test.js",
    "test:stress-engine": "node ./tests/stressEngine.test.js",
    "test:stress": "node ./tests/stressTest.test.js",
    "test:stress:integration": "node ./tests/stressIntegration.test.js --integration"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@napi-rs/canvas": "^0.1.80",
    "@pinecone-database/pinecone": "^6.1.4",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.0",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.16.0",
    "tesseract.js": "^6.0.1"
  }
}
