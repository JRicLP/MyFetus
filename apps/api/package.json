{
  "name": "@myfetus/api",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "jwt:secret:test": "NODE_ENV=test node ./scripts/generate-jwt-secret.js",
    "jwt:test-token": "node ./scripts/generate-jwt-test-token.js",
    "jwt:rotate:test": "node ./scripts/rotate-jwt-secret-and-generate-token.js",
    "extract:documents": "node workers/extractDocuments.js",
    "test:pii": "node ./tests/piiSanitizer.test.js",
    "test:logger": "node ./tests/logger.test.js",
    "test:db": "docker compose run --rm backend node /app/tests/database.test.js",
    "test:loinc": "docker compose run --rm backend node /app/tests/loincMapper.test.js",
    "test:loinc:endpoint": "docker compose run --rm backend node /app/tests/internalLoinc.test.js",
    "test:rag": "node ./tests/ragRetrieval.test.js"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.0",
    "pdfjs-dist": "^4.10.38",
    "tesseract.js": "^6.0.1",
    "pg": "^8.16.0"
  }
}
