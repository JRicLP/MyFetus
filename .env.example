# Banco de dados
PG_USER=myfetus_app
PG_PASSWORD=
PG_DATABASE=myfetus
PG_HOST=db
PG_PORT=5432
DB_ROTATION_HOST=localhost
DB_ROTATION_PORT=5434

# Backend
PORT=3000
JWT_SECRET=
JWT_EXPIRES_IN=8h
CORS_ORIGIN=
NODE_ENV=development
TRUST_PROXY=
ENFORCE_HTTPS=false
HSTS_MAX_AGE_SECONDS=31536000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
REGISTER_RATE_LIMIT_MAX=5
ADMIN_READ_RATE_LIMIT_MAX=100

# Criptografia em repouso
AES_KEY_VERSION=1
AES_ENCRYPTION_KEY_V1=
EMAIL_LOOKUP_HMAC_KEY=
DOCUMENT_STORAGE_DIR=uploads/encrypted
DOCUMENT_MAX_UPLOAD_BYTES=26214400
ORPHAN_FILE_MINIMUM_AGE_MS=3600000

# RAG - busca semântica (Pinecone)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=myfetus-rag
PINECONE_NAMESPACE=guidelines
EMBEDDING_MODEL=Xenova/multilingual-e5-small
EMBEDDING_DIMENSION=384

# RAG - geração da resposta do chat (Google Gemini, aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Simulador de estresse do RAG
RAG_BASE_URL=
RAG_TEST_JWT=
RAG_TIMEOUT_MS=5000
RAG_MAX_ATTEMPTS=2
RAG_RETRY_DELAY_MS=100
